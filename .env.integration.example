TOGETHER_API_KEY=your_together_key_here

# Use the Together model name; the script will prefix it with together_ai/ automatically.
GEPA_MODEL=Qwen/Qwen3-VL-8B-Instruct

# Comma-separated run modes. Default runs both.
GEPA_RUN_MODES=full_eval,heldout_eval

# Budget per run.
GEPA_MAX_METRIC_CALLS=50

# Small slices for a quick smoke test.
GEPA_TRAIN_SLICE=6
GEPA_VAL_SLICE=6
GEPA_HELD_OUT_SLICE=4
GEPA_TEST_SLICE=6

# Optional WandB logging.
GEPA_USE_WANDB=false
GEPA_WANDB_PROJECT=gepa-held-out-integration
GEPA_WANDB_RUN_PREFIX=aime-qwen3-vl-8b-smoke

# Optional generation cap.
GEPA_MAX_TOKENS=16384
